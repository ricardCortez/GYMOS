# GymOS - Variables de entorno
# Copia este archivo como .env y ajusta los valores:
#   cp .env.example .env

# ── Seguridad ──────────────────────────────────────────────────
# Clave secreta para firmar los JWT.
# Genera una segura con: python -c "import secrets; print(secrets.token_hex(32))"
GYMOS_SECRET=gymos-secret-key-CAMBIAME-en-produccion

# ── Servidor ───────────────────────────────────────────────────
# Puerto de escucha (default: 8000)
# GYMOS_PORT=8000

# En producción detrás de Nginx: escuchar solo en loopback
# GYMOS_HOST=127.0.0.1

# Número de workers Uvicorn.
# IMPORTANTE: Mantener en 1 — el reconocimiento facial usa caché en memoria.
# Múltiples workers tendrían cachés separadas y el registro fallaría.
# GYMOS_WORKERS=1

# ── Datos ──────────────────────────────────────────────────────
# Ruta alternativa para guardar la BD, audios, certificados y modelos IA.
# Útil cuando la base de datos debe estar en una partición separada.
# Si no se define, se usa la carpeta data/ dentro del proyecto.
# GYMOS_DATA_DIR=/opt/gymos/data
